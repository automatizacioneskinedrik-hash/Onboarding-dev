# Server
NODE_ENV=development
PORT=5000

# Frontend / CORS
# Comma-separated list when more than one origin is needed.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# OpenAI
# If OPENAI_API_KEY is empty, the backend uses fallback behavior for AI flows.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Storage                                  
# In production, Firestore is enabled automatically unless USE_FIRESTORE=false is set.
USE_FIRESTORE=false
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Uploads
MAX_FILE_SIZE_MB=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
USE_GOOGLE_CLOUD_LOGGING=false
CLOUD_LOGGING_LOG_NAME=application

